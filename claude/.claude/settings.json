{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "~/.config/tmux/plugins/tmux-claude-status/scripts/hook.sh UserPromptSubmit" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "~/.config/tmux/plugins/tmux-claude-status/scripts/hook.sh PreToolUse" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "~/.config/tmux/plugins/tmux-claude-status/scripts/hook.sh Stop" }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "~/.config/tmux/plugins/tmux-claude-status/scripts/hook.sh Notification" }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "mastersoft-statusline",
    "padding": 0
  },
  "permissions": {
    "allow": [
      "Bash(claude:*)",
      "Bash(date:*)",
      "WriteFile(**CLAUDE.md)",
      "Read(**CLAUDE.md)",
      "Edit(**CLAUDE.md)",
      "WriteFile(**/memory.md)",
      "Read(**/memory.md)",
      "Edit(**/memory.md)",
      "WriteFile(**/memory.local.md)",
      "Read(**/memory.local.md)",
      "Edit(**/memory.local.md)",
      "WriteFile(**/.claude/prd/**)",
      "Read(**/.claude/prd/**)",
      "Edit(**/.claude/prd/**)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh repo view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh api:*)",
      "Bash(gh auth status:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo clone:*)",
      "Bash(gh repo fork:*)",
      "Bash(gh gist create:*)",
      "Bash(gh workflow run:*)",
      "Bash(gh release create:*)",
      "Bash(codex:*)",
      "mcp__serena",
      "mcp__context7",
      "mcp__deepwiki"
    ],
    "deny": [],
    "defaultMode": "default"
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "superpowers@superpowers-marketplace": true,
    "frontend-design@claude-code-plugins": true,
    "mastersoft-core@mastersoft": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "mastersoft": {
      "source": {
        "source": "git",
        "url": "git@git.mastersoft.it:mastersoft/claude-plugins.git"
      }
    }
  },
  "effortLevel": "xhigh",
  "awaySummaryEnabled": false,
  "skipDangerousModePermissionPrompt": true
}
